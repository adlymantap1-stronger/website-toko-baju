{
  "version": 2,
  "framework": null,
  "outputDirectory": "public/build",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}